{
  "name": "nwp-forecast-zarr-creator",
  "dockerComposeFile": [
    "../docker-compose.dev.yml"
  ],
  "service": "app",
  "workspaceFolder": "/app",
  "overrideCommand": true,
  "shutdownAction": "stopCompose",
  "containerEnv": {
    "HOME": "/root",
    "JUPYTER_RUNTIME_DIR": "/root/.local/share/jupyter/runtime"
  },
  "remoteEnv": {
    "HOME": "/root",
    "JUPYTER_RUNTIME_DIR": "/root/.local/share/jupyter/runtime"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-azuretools.vscode-docker",
        "charliermarsh.ruff"
      ],
      "settings": {
          "python.defaultInterpreterPath": "/app/.venv/bin/python",
          "jupyter.logging.level": "trace",
          "jupyter.jupyterServerType": "local"
      }
    }
  },
  "postCreateCommand": "mkdir -p /root/.local/share/jupyter/runtime && uv sync --dev && uv pip uninstall debugpy"
}
